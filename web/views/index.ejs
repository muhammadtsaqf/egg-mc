<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= motd %> - Server Minecraft</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="background-animation"></div>
    
    <div class="glass-container">
        <header>
            <div class="logo-box">
                <!-- Using a blocky cube SVG as logo -->
                <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="url(#gradient)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <defs>
                        <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#00f2fe" />
                            <stop offset="100%" stop-color="#4facfe" />
                        </linearGradient>
                    </defs>
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                    <line x1="12" y1="22.08" x2="12" y2="12"></line>
                </svg>
            </div>
            <h1><%= motd %></h1>
            <p class="subtitle"><%= type.toUpperCase() %> • <%= version %></p>
        </header>

        <div class="status-card">
            <div class="status-indicator">
                <div id="status-dot" class="dot loading"></div>
                <span id="status-text">Memeriksa Server...</span>
            </div>
            <div class="player-count">
                <h2 id="player-numbers">--/--</h2>
                <p>Players Online</p>
            </div>
        </div>

        <div class="ip-section">
            <div class="ip-box" id="ip-box">
                <span id="ip-address">play.namadomainmu.com</span>
                <button id="copy-btn" title="Copy IP">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                </button>
            </div>
            <p class="copy-hint" id="copy-hint">Klik untuk menyalin IP</p>
        </div>

        <footer>
            <p>Powered by Antigravity Universal Egg</p>
        </footer>
    </div>

    <script>
        // Update IP based on current hostname (because we use CF Tunnel)
        const hostname = window.location.hostname;
        const ipSpan = document.getElementById('ip-address');
        if(hostname && hostname !== 'localhost' && hostname !== '127.0.0.1') {
            ipSpan.textContent = hostname;
        }

        // Copy IP Functionality
        document.getElementById('ip-box').addEventListener('click', () => {
            const ip = ipSpan.textContent;
            navigator.clipboard.writeText(ip).then(() => {
                const hint = document.getElementById('copy-hint');
                hint.textContent = 'IP Berhasil Disalin! 🎉';
                hint.style.color = '#00f2fe';
                setTimeout(() => {
                    hint.textContent = 'Klik untuk menyalin IP';
                    hint.style.color = 'rgba(255, 255, 255, 0.6)';
                }, 2000);
            });
        });

        // Fetch Live Server Status
        async function fetchStatus() {
            try {
                const res = await fetch('/api/status');
                const data = await res.json();
                
                const dot = document.getElementById('status-dot');
                const text = document.getElementById('status-text');
                const numbers = document.getElementById('player-numbers');

                dot.classList.remove('loading', 'online', 'offline');

                if(data.online) {
                    dot.classList.add('online');
                    text.textContent = 'Server Online';
                    numbers.textContent = `${data.players.online} / ${data.players.max}`;
                } else {
                    dot.classList.add('offline');
                    text.textContent = 'Server Offline / Starting...';
                    numbers.textContent = '0 / 0';
                }
            } catch(e) {
                console.error("Gagal mengambil status:", e);
            }
        }

        // Initial fetch and set interval
        fetchStatus();
        setInterval(fetchStatus, 10000); // Update every 10 seconds
    </script>
</body>
</html>
