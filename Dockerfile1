FROM node:20-slim

LABEL maintainer="azzamganteng921@gmail.com"
LABEL org.opencontainers.image.title="zzamcodes Multi-Function Egg"
LABEL org.opencontainers.image.description="Pterodactyl Multi-Function Docker Image - Node.js, Python, PHP, Go, Bun, Redis, MariaDB, Chromium, FFmpeg"
LABEL org.opencontainers.image.authors="zzamcodes <azzamganteng921@gmail.com>"
LABEL org.opencontainers.image.source="https://github.com/zzamcodes17/docker-multi-function"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.version="2.0"
LABEL org.opencontainers.image.vendor="zzamcodes"

SHELL ["/bin/bash", "-c"]

ENV HOME=/home/container
ENV CHROME_BIN=/usr/bin/chromium
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV DISPLAY=:99
ENV PYENV_ROOT=/opt/pyenv
ENV GOPATH=/home/container/go
ENV GOROOT=/usr/local/go
ENV PATH="$PYENV_ROOT/bin:$PYENV_ROOT/shims:/usr/local/go/bin:/home/container/go/bin:/root/.local/bin:$PATH"

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git unzip jq make nano sudo wget ca-certificates gnupg apt-transport-https \
    ffmpeg imagemagick \
    build-essential cmake pkg-config \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y --no-install-recommends \
    libcairo2-dev libpango1.0-dev libjpeg-dev libgif-dev librsvg2-dev \
    libatk1.0-0 libatk-bridge2.0-0 libgtk-3-0 \
    libnss3 libxss1 libasound2 libcups2 libdrm2 libgbm1 \
    libxcomposite1 libxdamage1 libxrandr2 libgbm-dev \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y --no-install-recommends \
    mariadb-server mariadb-client \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y --no-install-recommends \
    redis-server \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium xvfb \
    && chmod +x /usr/bin/chromium \
    && ln -sf /usr/bin/chromium /usr/bin/google-chrome \
    && ln -sf /usr/bin/chromium /usr/bin/google-chrome-stable \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium-driver \
    && chmod +x /usr/bin/chromium-driver \
    && ln -sf /usr/bin/chromium-driver /usr/bin/chromedriver \
    && apt-get clean && rm -rf /var/lib/apt/lists/* || echo "chromedriver install gagal, lanjut"

RUN npm install -g npm@latest pm2 n nodemon \
    && mkdir -p $HOME/.npm && chmod -R 777 $HOME/.npm

# Install multi-version PHP via Sury repository (7.4, 8.0, 8.1, 8.2, 8.3, 8.4)
RUN curl -sSLo /usr/share/keyrings/deb.sury.org-php.gpg https://packages.sury.org/php/apt.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/deb.sury.org-php.gpg] https://packages.sury.org/php/ bookworm main" > /etc/apt/sources.list.d/php.list \
    && apt-get update \
    && for VER in 7.4 8.0 8.1 8.2 8.3 8.4; do \
        apt-get install -y --no-install-recommends \
            php${VER} php${VER}-cli \
            php${VER}-curl php${VER}-mbstring php${VER}-xml \
            php${VER}-zip php${VER}-mysql php${VER}-gd \
            php${VER}-bcmath php${VER}-intl || echo "PHP ${VER} gagal, dilewati"; \
    done \
    && update-alternatives --set php /usr/bin/php8.2 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Python resmi via pyenv (compile dari source)
ENV PYENV_ROOT=/opt/pyenv
RUN apt-get update && apt-get install -y --no-install-recommends \
        libssl-dev libssl3 ca-certificates \
        libbz2-dev libffi-dev libgdbm-dev liblzma-dev libncursesw5-dev libreadline6-dev libsqlite3-dev tk-dev xz-utils zlib1g-dev \
    && git clone https://github.com/pyenv/pyenv.git $PYENV_ROOT \
    && $PYENV_ROOT/bin/pyenv install 3.9.19 \
    && $PYENV_ROOT/bin/pyenv install 3.10.14 \
    && $PYENV_ROOT/bin/pyenv install 3.11.9 \
    && $PYENV_ROOT/bin/pyenv install 3.12.2 \
    && $PYENV_ROOT/bin/pyenv install 3.13.0 \
    && $PYENV_ROOT/bin/pyenv global 3.11.9 \
    && ln -sf $PYENV_ROOT/versions/3.9.19/bin/python /usr/local/bin/python3.9 \
    && ln -sf $PYENV_ROOT/versions/3.10.14/bin/python /usr/local/bin/python3.10 \
    && ln -sf $PYENV_ROOT/versions/3.11.9/bin/python /usr/local/bin/python3.11 \
    && ln -sf $PYENV_ROOT/versions/3.11.9/bin/python /usr/local/bin/python3 \
    && ln -sf $PYENV_ROOT/versions/3.12.2/bin/python /usr/local/bin/python3.12 \
    && ln -sf $PYENV_ROOT/versions/3.13.0/bin/python /usr/local/bin/python3.13 \
    && ln -sf $PYENV_ROOT/versions/3.11.9/bin/python /usr/local/bin/python \
    && $PYENV_ROOT/versions/3.11.9/bin/python -m pip install --upgrade pip \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Pre-install Node.js LTS key versions via n (others download on-demand)
RUN n 16 && n 18 && n 20 && n 22 && n 23 && n 20

# Install semua versi Go (1.21, 1.22, 1.23, 1.24)
RUN ARCH=$(uname -m); \
    [ "$ARCH" = "x86_64" ] && GOARCH="amd64" || GOARCH="arm64"; \
    for VERSION in 1.21.13 1.22.12 1.23.8 1.24.2; do \
        MINOR=$(echo $VERSION | cut -d. -f1,2); \
        if curl -fsSL "https://dl.google.com/go/go${VERSION}.linux-${GOARCH}.tar.gz" | tar -C /usr/local -xz; then \
            mv /usr/local/go /usr/local/go-${MINOR}; \
            echo "✓ Go ${VERSION} installed"; \
        else \
            echo "Go ${VERSION} gagal, dilewati"; \
        fi; \
    done; \
    ln -sf /usr/local/go-1.23 /usr/local/go; \
    mkdir -p /home/container/go/bin /home/container/go/src /home/container/go/pkg

# Install speedtest-cli
RUN /usr/local/bin/python3.11 -m pip install speedtest-cli

# Install multi-version Java via SDKMAN (8, 11, 17, 21)
ENV SDKMAN_DIR=/root/.sdkman
ENV PATH="/root/.sdkman/candidates/java/current/bin:$PATH"
RUN apt-get update && apt-get install -y --no-install-recommends zip unzip \
    && apt-get clean && rm -rf /var/lib/apt/lists/* \
    && curl -s "https://get.sdkman.io" | bash \
    && bash -c "\
        source /root/.sdkman/bin/sdkman-init.sh \
        && sdk install java 8.0.402-tem \
        && sdk install java 11.0.22-tem \
        && sdk install java 17.0.10-tem \
        && sdk install java 21.0.2-tem \
        && sdk default java 21.0.2-tem"

RUN curl -fsSL https://bun.sh/install | BUN_INSTALL=/usr/local bash \
    && ln -sf /usr/local/bin/bun /usr/local/bin/bunx

RUN ARCH=$(uname -m); \
    if [ "$ARCH" = "x86_64" ]; then ARCH="amd64"; elif [ "$ARCH" = "aarch64" ]; then ARCH="arm64"; fi; \
    curl -L "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${ARCH}" -o /usr/local/bin/cloudflared; \
    chmod +x /usr/local/bin/cloudflared

WORKDIR /home/container

COPY index.sh /index.sh
RUN chmod +x /index.sh

RUN npm config set cache $HOME/.npm

RUN echo "alias apt='echo \"Apt install is disabled\"'" >> ~/.bashrc

CMD ["/index.sh"]
